{
  "name": "coop-food-distribution",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node -e \"const fs=require('fs');const path=require('path');const copy=(src,dst)=>{if(!fs.existsSync(src))return;fs.rmSync(dst,{recursive:true,force:true});fs.mkdirSync(dst,{recursive:true});fs.cpSync(src,dst,{recursive:true});};copy(path.join('.next','static'),path.join('.next','standalone','.next','static'));copy('public',path.join('.next','standalone','public'));\"",
    "start": "set DOTENV_CONFIG_PATH=.env.local&& node -r dotenv/config .next/standalone/server.js",
    "lint": "eslint"
  },
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.56.0",
    "axios": "^1.12.0",
    "dotenv": "^17.2.2",
    "exceljs": "^4.4.0",
    "jspdf": "^3.0.2",
    "jspdf-autotable": "^5.0.2",
    "next": "^15.5.2",
    "pg": "^8.16.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/react": "19.1.11",
    "eslint": "^9",
    "eslint-config-next": "^15.5.2",
    "tailwindcss": "^4"
  }
}
